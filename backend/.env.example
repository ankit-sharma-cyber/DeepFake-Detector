# ============================================================
# Oracle's Decree Backend — Environment Variables
# Copy this file to .env and fill in your actual keys
# ============================================================

# HuggingFace Inference API Token
# Required for image and video deepfake detection (dual-model ensemble)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=

# Google Gemini API Key
# Used ONLY for generating a 3-sentence forensic summary after verdict is determined
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production

# Upload settings
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=mp4,avi,mov,mkv,wav,mp3,flac,jpg,jpeg,png,webp

# Tuning
CONFIDENCE_THRESHOLD=0.85
AMBIGUITY_MARGIN=0

# Data & misc
DATA_DIR=data
DATA_RETENTION_DAYS=30
FRONTEND_URL=http://localhost:5173
